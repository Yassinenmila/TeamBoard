@startuml

' =========================
' CLASSE ABSTRAITE USER
' =========================
abstract class User {
  +id: bigint
  +firstName: string
  +lastName: string
  +email: string
  +password: string
  +role: string
  +createdAt: datetime
  +updatedAt: datetime

  +login(): boolean
  +logout(): void
}

' =========================
' HERITAGE (ROLES)
' =========================

class Admin {
  +gererUsers(): void
  +validerDemande(d: Demande): void
}

class Responsable {
  +creerTache(): Tache
  +organiserReunion(): Reunion
}

class Membre {
  +repondreInvitation(i: Invitation): void
  +commenter(c: Commentaire): void
}

User <|-- Admin
User <|-- Responsable
User <|-- Membre

' =========================
' CLASSES METIER
' =========================

class Annonce {
  +id: bigint
  +titre: string
  +contenu: text
  +type: string
  +createdAt: datetime
  +updatedAt: datetime
}

class Demande {
  +id: bigint
  +type: string
  +description: text
  +status: string
  +date: date
}

class Tache {
  +id: bigint
  +titre: string
  +description: text
  +status: string
  +dateLimite: datetime
}

class Reunion {
  +id: bigint
  +titre: string
  +description: text
  +date: date
  +heure: time
  +lieu: string
}

class Commentaire {
  +id: bigint
  +contenu: text
  +createdAt: datetime
}

class Notification {
  +id: bigint
  +message: string
  +lu: boolean
  +createdAt: datetime

  +marquerCommeLu(): void
}

' =========================
' TABLES PIVOTS (MANY TO MANY)
' =========================

class Affectation {
  +status: string
  +createdAt: datetime
}

class Invitation {
  +status: string
  +createdAt: datetime
}

' =========================
' RELATIONS USER
' =========================

User "1" -- "0..*" Annonce : publie
User "1" -- "0..*" Demande : crée
User "1" -- "0..*" Tache : crée
User "1" -- "0..*" Reunion : organise
User "1" -- "0..*" Commentaire : écrit

' =========================
' MANY TO MANY
' =========================

User "1" -- "0..*" Affectation
Tache "1" -- "0..*" Affectation

User "1" -- "0..*" Invitation
Reunion "1" -- "0..*" Invitation

' =========================
' COMPOSITION
' =========================

Annonce "1" *-- "0..*" Commentaire
Tache "1" *-- "0..*" Commentaire
Reunion "1" *-- "0..*" Commentaire

' =========================
' AGREGATION
' =========================

User "1" o-- "0..*" Notification

@enduml