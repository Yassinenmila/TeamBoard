@startuml TeamBoard_Classes_Improved

' ===== Roles =====
enum Role {
    ADMIN
    RESPONSABLE
    MEMBRE
}

' ===== Utilisateur (Abstraction) =====
abstract class Utilisateur {
    -id: int
    -nom: string
    -email: string
    -password: string
    -role: Role
}

class Admin
class Responsable
class Membre

Utilisateur <|-- Admin
Utilisateur <|-- Responsable
Utilisateur <|-- Membre

' ===== Demandes (Abstraction) =====
abstract class Demande {
    -id: int
    -type: string
    -description: text
    -statut: string
    -date: DateTime
}

class DemandeAdmin
class DemandePoste
class DemandeTemps
class DemandeContrat

Demande <|-- DemandeAdmin
Demande <|-- DemandePoste
Demande <|-- DemandeTemps
Demande <|-- DemandeContrat

' ===== Tâches =====
class Tache {
    -id: int
    -titre: string
    -description: text
    -dateLimite: DateTime
    -statut: string
    -priorite: string
}

class Affectation {
    -id: int
}

' ===== Commentaire =====
class Commentaire {
    -id: int
    -contenu: text
    -date: DateTime
}

' ===== Annonces =====
enum TypeAnnonce {
    GENERALE
    URGENTE
}

class Annonce {
    -id: int
    -titre: string
    -contenu: text
    -datePublication: DateTime
    -type: TypeAnnonce
}

' ===== Réunions =====
class Reunion {
    -id: int
    -titre: string
    -description: text
    -date: DateTime
    -lieu: string
}

class Invitation {
    -id: int
    -statut: string
}

' ===== Notification (Abstraction) =====
abstract class Notification {
    -id: int
    -message: string
    -lu: boolean
    -date: DateTime
}

class NotifDemande
class NotifTache
class NotifReunion

Notification <|-- NotifDemande
Notification <|-- NotifTache
Notification <|-- NotifReunion

' ===== Relations =====
Utilisateur "1" --> "*" Demande : crée

Utilisateur "1" --> "*" Tache : crée
Tache "1" --> "*" Affectation
Utilisateur "1" --> "*" Affectation

Tache "1" --> "*" Commentaire
Demande "1" --> "*" Commentaire
Utilisateur "1" --> "*" Commentaire

Utilisateur "1" --> "*" Annonce : publie

Utilisateur "1" --> "*" Reunion : crée
Reunion "1" --> "*" Invitation
Utilisateur "1" --> "*" Invitation


Utilisateur "1" --> "*" Notification

@enduml